---
import { getCollection } from 'astro:content';
import { IoClose } from 'react-icons/io5';

interface Props {
	activeTag?: string;
}

const { activeTag } = Astro.props;

const allPosts = await getCollection('blog');
const sorted = allPosts.sort((a, b) => new Date(b.data.createdAt).valueOf() - new Date(a.data.createdAt).valueOf());

const seenTags = new Set<string>();
const recentTags: string[] = [];
for (const post of sorted) {
	for (const tag of post.data.tags ?? []) {
		if (!seenTags.has(tag)) {
			seenTags.add(tag);
			recentTags.push(tag);
			if (recentTags.length === 8) break;
		}
	}
	if (recentTags.length === 8) break;
}

if (activeTag && !recentTags.includes(activeTag)) {
	recentTags.unshift(activeTag);
	recentTags.pop();
}
---

<div class="flex flex-wrap gap-2 mt-6">
	{recentTags.map((tag) => (
		activeTag === tag ? (
			<a
				href="/blog"
				class="inline-flex items-center gap-1.5 px-3 py-1 rounded text-sm font-medium border bg-green text-bg0 border-green [transition:border-color_150ms,color_500ms,background-color_500ms]"
			>
				{tag}
				<IoClose className="w-3 h-3" />
			</a>
		) : (
			<a
				href={`/blog/${tag}`}
				class="group inline-flex items-center gap-1.5 px-3 py-1 rounded text-sm font-medium border bg-bg1 border-bg2 hover:border-green [transition:border-color_150ms,background-color_500ms]"
			>
				<span class="relative">
					<span class="text-fg-dim [transition:opacity_150ms,color_500ms] group-hover:opacity-0">{tag}</span>
					<span class="absolute inset-0 text-fg opacity-0 group-hover:opacity-100 [transition:opacity_150ms,color_500ms]">{tag}</span>
				</span>
			</a>
		)
	))}
</div>
