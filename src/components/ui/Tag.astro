---
interface Props {
	tag: string;
	href: string;
}

const { tag, href } = Astro.props;
---

<a
	href={href}
	class="group relative inline-flex items-center gap-1.5 px-3 py-1 rounded text-sm font-medium border bg-bg1 border-bg2 [transition:background-color_500ms,border-color_500ms]"
>
	<span class="absolute inset-0 rounded border border-green opacity-0 group-hover:opacity-100 [transition:opacity_150ms] pointer-events-none" aria-hidden="true"></span>
	<span class="relative">
		<span class="text-fg-dim [transition:opacity_150ms,color_500ms] group-hover:opacity-0">{tag}</span>
		<span class="absolute inset-0 text-fg opacity-0 group-hover:opacity-100 [transition:opacity_150ms,color_500ms]">{tag}</span>
	</span>
</a>
