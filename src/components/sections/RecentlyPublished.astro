---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { getCollection, render } from 'astro:content';
import { IoArrowForward, IoCalendarOutline, IoTimeOutline } from 'react-icons/io5';
import FormattedDate from '@/components/ui/FormattedDate.astro';

const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/*.{jpeg,jpg,png,gif}');

const allPosts = await getCollection('blog');
const posts = allPosts
	.sort((a, b) => new Date(b.data.createdAt).valueOf() - new Date(a.data.createdAt).valueOf())
	.slice(0, 3);

const postsWithMeta = await Promise.all(
	posts.map(async (post) => {
		const { remarkPluginFrontmatter } = await render(post);
		return { post, minutesRead: remarkPluginFrontmatter.minutesRead };
	})
);
---

<section class="mb-16">
	<h2 class="text-2xl font-mplus font-medium mb-2">Recently Published</h2>
	<p class="mb-8 text-base text-fg-dim">I write about infrastructure automation, Kubernetes, and self-hosting.</p>
	<ul class="grid grid-cols-1 md:grid-cols-3 gap-6">
		{
			postsWithMeta.map(({ post, minutesRead }) => {
				const heroImageAsset = post.data.heroImage && images[post.data.heroImage];
				const heroImageSrc = heroImageAsset ? heroImageAsset() : post.data.heroImage;
				return (
					<li class="border border-bg2 rounded-lg overflow-hidden shadow-lg hover:shadow-xl flex flex-col h-full [transition:box-shadow_150ms,border-color_500ms]">
						<a href={`/blog/${post.id}`} class="flex flex-col h-full">
							{heroImageSrc && (
								<div class="relative">
									<Image
										class="w-full h-[140px] object-cover border-b border-bg2 transition-[opacity,border-color] duration-[470ms] opacity-100 dark:opacity-0"
										src={heroImageSrc.replace('-dark.png', '-light.png')}
										width={720}
										height={140}
										alt="Banner"
									/>
									<Image
										class="w-full h-[140px] object-cover border-b border-bg2 transition-[opacity,border-color] duration-[470ms] absolute top-0 left-0 opacity-0 dark:opacity-100"
										src={heroImageSrc.replace('-light.png', '-dark.png')}
										width={720}
										height={140}
										alt="Banner"
									/>
								</div>
							)}
							<div class="p-6 flex flex-col flex-grow">
								<h3 class="text-xl font-bold font-mplus mb-3">
									{post.data.title}
								</h3>
								{post.data.tags && (
									<div class="flex flex-wrap gap-2 mb-3">
										{post.data.tags.slice(0, 3).map((tag) => (
											<span class="text-xs px-2 py-1 bg-bg1 text-green rounded">
												#{tag}
											</span>
										))}
									</div>
								)}
								{post.data.description && (
									<p class="text-sm text-fg-dim mb-4 line-clamp-2">
										{post.data.description}
									</p>
								)}
								<div class="mt-auto">
									<hr class="border-bg2 mb-4" />
									<div class="flex items-center text-sm text-fg-dim gap-3">
										{post.data.createdAt && (
											<div class="flex items-center gap-1">
												<IoCalendarOutline className="w-4 h-4" />
												<FormattedDate date={new Date(post.data.createdAt)} />
											</div>
										)}
										<div class="flex items-center gap-1">
											<IoTimeOutline className="w-4 h-4" />
											<span>{minutesRead || '5 min read'}</span>
										</div>
									</div>
								</div>
							</div>
						</a>
					</li>
				);
			})
		}
	</ul>
	<div class="flex justify-end mt-6">
		<a
			href="/blog"
			class="group flex items-center gap-1 text-sm text-fg-dim"
		>
			View all posts
			<IoArrowForward className="w-4 h-4 transition-transform duration-150 group-hover:translate-x-1" />
		</a>
	</div>
</section>
