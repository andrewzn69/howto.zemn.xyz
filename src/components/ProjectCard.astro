---
import { IoStar, IoGitBranch, IoArrowForward } from 'react-icons/io5';

interface Props {
	name: string;
	description: string;
	topics: string[];
	stars: number;
	forks: number;
	url: string;
}

const { name, description, topics, stars, forks, url } = Astro.props;
---

<div class="border border-bg5 rounded p-6 hover:border-green transition-colors">
	<div class="flex flex-wrap gap-2 mb-3">
		{topics.slice(0, 5).map((topic) => (
			<span class="text-xs px-2 py-1 bg-bg1 text-green rounded">{topic}</span>
		))}
	</div>

	<h3 class="text-xl font-mplus font-semibold mb-2">{name}</h3>

	<p class="text-fg-dim mb-4 text-sm">{description || 'No description available'}</p>

	<div class="flex items-center justify-between pt-4 border-t border-bg5">
		<div class="flex gap-4 text-sm text-fg-dim">
			<span class="flex items-center gap-1">
				<IoStar className="w-4 h-4" />
				{stars}
			</span>
			<span class="flex items-center gap-1">
				<IoGitBranch className="w-4 h-4" />
				{forks}
			</span>
		</div>

		<a
			href={url}
			target="_blank"
			class="group flex items-center gap-1 text-sm text-fg-dim"
		>
			Source
			<IoArrowForward className="w-4 h-4 transition-transform group-hover:translate-x-1" />
		</a>
	</div>
</div>
